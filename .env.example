# Copy to .env.local and fill in.

# Required: your Anthropic API key.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the models used by the pipeline.
# Route is a cheap classification call; Operate does the doc editing.
ROUTE_MODEL=claude-haiku-4-5-20251001
OPERATE_MODEL=claude-sonnet-5

# Optional: routing confidence below this goes to the Inbox instead of auto-applying.
ROUTE_CONFIDENCE_THRESHOLD=0.6

# Optional: where the SQLite file lives (defaults to ./data/ledger.db).
DATABASE_PATH=./data/ledger.db
