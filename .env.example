# Copy to .env.local and adjust if needed.

# LLM backend: a local Ollama server (https://ollama.com). No API key, no credits.
# Pull a model first, e.g.  ollama pull llama3.1:8b
# OLLAMA_URL is the server BASE url — no /api path (a trailing /api/chat is tolerated).
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Optional: routing confidence below this goes to the Inbox instead of auto-applying.
ROUTE_CONFIDENCE_THRESHOLD=0.6

# Optional: where the SQLite file lives (defaults to ./data/ledger.db).
DATABASE_PATH=./data/ledger.db
